{
  "name": "flui-cli",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index-full-dynamic.js",
    "dev": "ts-node src/index-ultra-dynamic.ts",
    "flui": "ts-node src/index-ultra-dynamic.ts",
    "flui-dynamic": "ts-node src/index-full-dynamic.ts",
    "flui-old": "ts-node src/index-production.ts",
    "test": "cd tests && npm test",
    "test:unit": "cd tests && npm run test:unit",
    "test:integration": "cd tests && npm run test:integration",
    "test:e2e": "cd tests && npm run test:e2e",
    "test:watch": "cd tests && jest --watch",
    "test:coverage": "cd tests && npm run test:coverage",
    "test:all": "cd tests && npm run test:all",
    "test:install": "cd tests && npm install",
    "clean": "rm -rf dist test-output flui-autonomous-*",
    "rebuild": "npm run clean && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Flui CLI - Chat dinâmico com LLM usando api.llm7.io",
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.12",
    "@types/marked": "^4.3.2",
    "@types/node": "^20.11.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@types/express": "^5.0.3",
    "axios": "^1.7.9",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "express": "^5.1.0",
    "inquirer": "^8.2.6",
    "marked": "^4.3.0",
    "marked-terminal": "^5.2.0",
    "openai": "^5.16.0",
    "ora": "^5.4.1",
    "readline-sync": "^1.4.10"
  }
}
