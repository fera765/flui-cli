{
  "name": "flui-tests",
  "version": "1.0.0",
  "description": "Test suite for Flui cascade agents and spiral orchestration",
  "scripts": {
    "test": "jest",
    "test:unit": "jest unit/",
    "test:integration": "jest integration/",
    "test:e2e": "jest e2e/",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:debug": "DEBUG=true jest --detectOpenHandles",
    "test:production": "NODE_ENV=production jest integration/",
    "test:all": "npm run test:unit && npm run test:integration",
    "clean": "rm -rf coverage test-output"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "boxen": "^5.1.2"
  }
}